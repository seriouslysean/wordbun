---
import SectionHeading from '#components/SectionHeading.astro';
import WordLink from '#components/WordLink.astro';
import type { WordData } from '#types';
import { t } from '#utils/i18n-utils';

interface Props {
  wordLength: number;
  partOfSpeech?: string;
  year?: string;
  byLength: WordData[];
  byPartOfSpeech: WordData[];
  byYear: WordData[];
}

const { wordLength, partOfSpeech, year, byLength, byPartOfSpeech, byYear } = Astro.props;

const sections: Array<{ key: string; label: string; words: WordData[] }> = [];

if (byLength.length > 0) {
  sections.push({
    key: 'length',
    label: t('word.more_by_length', { length: wordLength }),
    words: byLength,
  });
}

if (partOfSpeech && byPartOfSpeech.length > 0) {
  sections.push({
    key: 'pos',
    label: t('word.more_by_part_of_speech', { partOfSpeech }),
    words: byPartOfSpeech,
  });
}

if (year && byYear.length > 0) {
  sections.push({
    key: 'year',
    label: t('word.more_from_year', { year }),
    words: byYear,
  });
}

const hasAny = sections.length > 0;
---

{hasAny && (
  <section class="word-related" aria-label={t('word.related_more_section')}>
    <SectionHeading text={t('word.related_more_section')} />
    <div class="word-related__sections">
      {sections.map(section => (
        <div class="word-related__section">
          <h3 class="word-related__subheading">{section.label}</h3>
          <ul class="word-related__list">
            {section.words.map(word => (
              <li class="word-related__item"><WordLink word={word} compact /></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .word-related {
    width: 100%;
    max-width: var(--content-width-small);
    margin: var(--spacing-large) auto calc(var(--spacing-large) * 2);
    padding: 0 var(--spacing-base);
  }

  .word-related__sections {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-large);
    margin-top: var(--spacing-base);
  }

  .word-related__subheading {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }

  .word-related__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .word-related__item {
    padding: 0;
  }

  @media (min-width: 768px) {
    .word-related__sections {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }
  }
</style>
