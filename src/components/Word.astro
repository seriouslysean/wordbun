---
import Heading from '#components/Heading.astro';
import WordEtymology from '#components/WordEtymology.astro';
import WordMeta from '#components/WordMeta.astro';
import WordSenses from '#components/WordSenses.astro';
import WordSynonyms from '#components/WordSynonyms.astro';
import type { WordData } from '#types';
import { formatDate, formatISODate } from '#utils/date-utils';
import { getWordSenses } from '#utils/word-data-utils';
import { corpusWordSet, getWordDetails } from '#astro-utils/word-data-utils';

interface Props {
  word: WordData | null;
}

const { word } = Astro.props;

// Handle case when no word is available
if (!word) {
  throw new Error('Word not found');
}

const { meta } = getWordDetails(word);
const senses = getWordSenses(word);
const enrichment = word.enrichment ?? null;
---

<article class="word">
  <div class="word__hero">
    <time class="word__date" datetime={formatISODate(word.date)} title={formatDate(word.date)}>{formatDate(word.date) || ' '}</time>
    <Heading level={1} text={word.word} id="word-title" preserveCase={word.preserveCase} />
    {word.date && <WordMeta word={word.word} enrichment={enrichment} />}
    <WordSenses senses={senses} meta={meta} />
  </div>
  <div class="word__details">
    <WordEtymology etymology={enrichment?.etymology} />
    <WordSynonyms
      word={word.word}
      synonyms={enrichment?.synonyms}
      antonyms={enrichment?.antonyms}
      related={enrichment?.related}
      knownWords={corpusWordSet}
    />
  </div>
</article>

<style>
    .word {
        text-align: center;
        width: 100%;
        max-width: var(--content-width-full);
        margin: 0 auto;
    }

    /* Hero: word + meta + senses fill ~the first viewport, vertically centered.
       min-height (never height) lets a long sense list grow and push the details
       below the fold rather than clipping the top of the hero. */
    .word__hero {
        min-height: calc(100svh - var(--header-height));
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .word__date {
        display: block;
        font-size: var(--font-size-xs, 0.75rem);
        color: var(--color-text-light);
        margin-bottom: var(--spacing-small);
    }

</style>
