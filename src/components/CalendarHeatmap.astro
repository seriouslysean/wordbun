---
import { buildActivityCalendar } from '#utils/calendar-utils';
import { formatDate } from '#utils/date-utils';
import { t, tp } from '#utils/i18n-utils';

interface Props {
  dates: string[];
}

const { dates } = Astro.props;
const calendars = buildActivityCalendar(dates).toReversed();
---

{calendars.length > 0 && (
  <div class="heatmap">
    {calendars.map(calendar => (
      <figure class="heatmap__year">
        <figcaption class="heatmap__caption">{calendar.year} · {tp('common.words', calendar.total)}</figcaption>
        <div class="heatmap__grid" role="img" aria-label={t('stats.activity_aria', { year: calendar.year })}>
          {calendar.cells.map(cell => (
            cell.date
              ? (
                <span
                  class:list={['heatmap__cell', { 'heatmap__cell--active': cell.active }]}
                  title={cell.active ? `${formatDate(cell.date)} · ${tp('common.words', 1)}` : formatDate(cell.date)}
                ></span>
              )
              : <span class="heatmap__cell heatmap__cell--empty"></span>
          ))}
        </div>
      </figure>
    ))}
  </div>
)}

<style>
  .heatmap {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-base);
  }

  .heatmap__caption {
    font-size: var(--font-size-small);
    color: var(--color-text-light);
    margin-bottom: var(--spacing-xs);
  }

  /* 7 rows (days), columns flow as weeks — a GitHub-style contributions grid. */
  .heatmap__grid {
    display: grid;
    grid-template-rows: repeat(7, 1fr);
    grid-auto-flow: column;
    grid-auto-columns: 1fr;
    gap: 3px;
    overflow-x: auto;
    padding-bottom: var(--spacing-xs);
  }

  .heatmap__cell {
    aspect-ratio: 1;
    min-width: 9px;
    border-radius: 2px;
    background: var(--color-border);
  }

  .heatmap__cell--active {
    background: var(--color-primary);
  }

  .heatmap__cell--empty {
    background: transparent;
  }
</style>
