---
import { buildActivityCalendar } from '#utils/calendar-utils';
import { formatDate } from '#utils/date-utils';
import { t, tp } from '#utils/i18n-utils';

interface Props {
  dates: string[];
}

const { dates } = Astro.props;
const calendars = buildActivityCalendar(dates).toReversed();
---

{calendars.length > 0 && (
  <div class="heatmap">
    {calendars.map(calendar => (
      <figure class="heatmap__year">
        <figcaption class="heatmap__caption">{calendar.year} · {tp('common.words', calendar.total)}</figcaption>
        <div
          class:list={['heatmap__grid', `heatmap__grid--cols-${calendar.columns}`]}
          role="img"
          aria-label={t('stats.activity_aria', { year: calendar.year })}
        >
          {calendar.cells.map(cell => (
            cell.date
              ? (
                <span
                  class:list={['heatmap__cell', { 'heatmap__cell--active': cell.active }]}
                  title={cell.active ? `${formatDate(cell.date)} · ${tp('common.words', 1)}` : formatDate(cell.date)}
                ></span>
              )
              : <span class="heatmap__cell"></span>
          ))}
        </div>
      </figure>
    ))}
  </div>
)}

<style>
  .heatmap {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-base);
  }

  .heatmap__caption {
    font-size: var(--font-size-small);
    color: var(--color-text-light);
    margin-bottom: var(--spacing-xs);
  }

  /* 7 rows (days), columns flow as weeks — a GitHub-style contributions grid.
     Full-width and responsive: cells are 1fr tracks and the grid's aspect-ratio
     keeps them square. Every year shares the same column count (set by the util)
     so all grids align; the count is baked into a static class because a strict
     CSP forbids inline style attributes. */
  /* Fluid gap -- ~1px where 53 columns crowd on phones, up to 2px on wider
     screens -- so the cells read as a contiguous grid at any width, no breakpoint. */
  .heatmap__grid {
    display: grid;
    grid-template-rows: repeat(7, 1fr);
    grid-auto-flow: column;
    gap: clamp(1px, 0.3vw, 2px);
    width: 100%;
  }

  .heatmap__grid--cols-53 {
    grid-template-columns: repeat(53, 1fr);
    aspect-ratio: 53 / 7;
  }

  .heatmap__grid--cols-54 {
    grid-template-columns: repeat(54, 1fr);
    aspect-ratio: 54 / 7;
  }

  /* Non-active cells (empty in-year days and leading/trailing padding) are faint
     squares; active days fill solid. */
  .heatmap__cell {
    border-radius: 2px;
    background: var(--color-border);
    opacity: 0.5;
  }

  .heatmap__cell--active {
    background: var(--color-primary);
    opacity: 1;
  }
</style>
