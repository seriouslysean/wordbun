---
import WordComponent from '#components/Word.astro';
import WordNav from '#components/WordNav.astro';
import WordAlphaNav from '#components/WordAlphaNav.astro';
import WordContext from '#components/WordContext.astro';
import Layout from '#layouts/Layout.astro';
import type { WordData } from '#types';
import { STRUCTURED_DATA_TYPE } from '#astro-utils/schema-utils.ts';
import { getMetaDescription } from '#astro-utils/seo-utils.ts';
import { extractWordDefinition } from '#astro-utils/word-data-utils';
import { t } from '#utils/i18n-utils';

interface Props {
  wordData: WordData;
  previousWord: WordData | null;
  nextWord: WordData | null;
  alphaPreviousWord?: WordData | null;
  alphaNextWord?: WordData | null;
  structuredDataType?: string;
  contextData?: {
    wordLength: number;
    firstLetter: string;
    partOfSpeech?: string;
    year?: string;
    lengthCount: number;
    letterCount: number;
    partOfSpeechCount?: number;
    yearCount?: number;
    relatedByLength?: WordData[];
    relatedByLetter?: WordData[];
    relatedByPartOfSpeech?: WordData[];
    relatedByYear?: WordData[];
  };
}

const { wordData, previousWord, nextWord, alphaPreviousWord = null, alphaNextWord = null, structuredDataType = STRUCTURED_DATA_TYPE.WORD_SINGLE, contextData } = Astro.props;

// Extract definition using shared utility
const { definition } = extractWordDefinition(wordData);
const pageDescription = getMetaDescription({
  word: wordData.word,
  definition,
});
---

<Layout
  title={wordData.word}
  word={wordData}
  description={pageDescription}
  structuredDataType={structuredDataType}
>

    <WordComponent word={wordData} />
    {contextData && (
      <WordContext
        wordLength={contextData.wordLength}
        firstLetter={contextData.firstLetter}
        partOfSpeech={contextData.partOfSpeech}
        year={contextData.year}
        lengthCount={contextData.lengthCount}
        letterCount={contextData.letterCount}
        partOfSpeechCount={contextData.partOfSpeechCount}
        yearCount={contextData.yearCount}
        relatedByLength={contextData.relatedByLength}
        relatedByLetter={contextData.relatedByLetter}
        relatedByPartOfSpeech={contextData.relatedByPartOfSpeech}
        relatedByYear={contextData.relatedByYear}
      />
    )}
    <WordNav
      previousWord={previousWord}
      nextWord={nextWord}
      previousLabel={t('nav.previous_word')}
      nextLabel={t('nav.next_word')}
    />
    <WordAlphaNav previousWord={alphaPreviousWord} nextWord={alphaNextWord} />

</Layout>
