---
import { getUrl, getWordUrl } from '#astro-utils/url-utils';
import type { WordCluster } from '#utils/word-graph-utils';

interface Props {
  clusters: WordCluster[];
}

const { clusters } = Astro.props;
---

{clusters.length > 0 && (
  <ul class="word-clusters">
    {clusters.map(cluster => (
      <li class="word-clusters__group">
        <ul class="word-clusters__chips">
          {cluster.words.map(word => (
            <li>
              <a class="word-clusters__chip" href={getUrl(getWordUrl(word))}>{word}</a>
            </li>
          ))}
        </ul>
      </li>
    ))}
  </ul>
)}

<style>
  .word-clusters {
    list-style: none;
    width: 100%;
    max-width: var(--content-width-small);
    margin: 0 auto;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-base);
  }

  /* Each connected set is a divider-separated group of its member words. */
  .word-clusters__group {
    padding-top: var(--spacing-base);
    border-top: 1px solid var(--color-border);
  }

  .word-clusters__group:first-child {
    padding-top: 0;
    border-top: none;
  }

  .word-clusters__chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-small);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .word-clusters__chip {
    display: inline-block;
    padding: var(--spacing-xs) var(--spacing-small);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    font-size: var(--font-size-small);
    color: var(--color-text-primary);
    text-decoration: none;
    transition: var(--transition);
  }

  .word-clusters__chip:hover {
    border-color: var(--color-primary);
  }
</style>
