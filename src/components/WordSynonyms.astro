---
import SectionHeading from '#components/SectionHeading.astro';
import { getUrl, getWordUrl } from '#astro-utils/url-utils';
import { splitKnownWords } from '#utils/word-data-utils';
import { t } from '#utils/i18n-utils';

interface Props {
  synonyms?: string[];
  antonyms?: string[];
  related?: string[];
  knownWords: Set<string>;
}

const { synonyms = [], antonyms = [], related = [], knownWords } = Astro.props;

const groups = [
  { key: 'synonyms', heading: t('word.synonyms_heading'), terms: synonyms },
  { key: 'antonyms', heading: t('word.antonyms_heading'), terms: antonyms },
  { key: 'related', heading: t('word.related_terms_heading'), terms: related },
].filter(group => group.terms.length > 0);
---

{groups.length > 0 && (
  <section class="word-relations">
    {groups.map(group => {
      const { known, unknown } = splitKnownWords(group.terms, knownWords);
      return (
        <div class="word-relations__group">
          <SectionHeading text={group.heading} align="center" underline={false} />
          <ul class="word-relations__chips">
            {known.map(term => (
              <li>
                <a class="word-relations__chip word-relations__chip--link" href={getUrl(getWordUrl(term))}>{term}</a>
              </li>
            ))}
            {unknown.map(term => (
              <li>
                <span class="word-relations__chip">{term}</span>
              </li>
            ))}
          </ul>
        </div>
      );
    })}
  </section>
)}

<style>
  .word-relations {
    width: 100%;
    max-width: var(--content-width-small);
    margin: var(--spacing-large) auto 0;
    padding: 0 var(--spacing-base);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-base);
  }

  .word-relations__chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-small);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .word-relations__chip {
    display: inline-block;
    padding: var(--spacing-xs) var(--spacing-small);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    font-size: var(--font-size-small);
    color: var(--color-text-light);
    text-decoration: none;
  }

  .word-relations__chip--link {
    color: var(--color-text-primary);
    transition: var(--transition);
  }

  .word-relations__chip--link:hover {
    border-color: var(--color-primary);
  }
</style>
