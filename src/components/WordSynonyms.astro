---
import SectionHeading from '#components/SectionHeading.astro';
import { getUrl, getWordUrl } from '#astro-utils/url-utils';
import { corpusRelations } from '#utils/word-data-utils';
import { t } from '#utils/i18n-utils';

interface Props {
  word: string;
  synonyms?: string[];
  antonyms?: string[];
  related?: string[];
  knownWords: Set<string>;
}

const { word, synonyms = [], antonyms = [], related = [], knownWords } = Astro.props;

// Relations are corpus-scoped: each group keeps only the terms that resolve to a
// real word page (matched after derivational resolution, self-links dropped).
// Groups with no corpus matches are dropped, and the section hides when empty.
const groups = [
  { key: 'synonyms', heading: t('word.synonyms_heading'), terms: corpusRelations(word, synonyms, knownWords) },
  { key: 'antonyms', heading: t('word.antonyms_heading'), terms: corpusRelations(word, antonyms, knownWords) },
  { key: 'related', heading: t('word.related_terms_heading'), terms: corpusRelations(word, related, knownWords) },
].filter(group => group.terms.length > 0);
---

{groups.length > 0 && (
  <section class="word-relations">
    {groups.map(group => (
      <div class="word-relations__group">
        <SectionHeading text={group.heading} align="center" underline={false} />
        <ul class="word-relations__chips">
          {group.terms.map(term => (
            <li>
              <a class="word-relations__chip word-relations__chip--link" href={getUrl(getWordUrl(term))}>{term}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>
)}

<style>
  .word-relations {
    width: 100%;
    max-width: var(--content-width-small);
    margin: var(--spacing-large) auto 0;
    padding: 0 var(--spacing-base);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-base);
  }

  .word-relations__chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-small);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .word-relations__chip {
    display: inline-block;
    padding: var(--spacing-xs) var(--spacing-small);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    font-size: var(--font-size-small);
    color: var(--color-text-light);
    text-decoration: none;
  }

  .word-relations__chip--link {
    color: var(--color-text-primary);
    transition: var(--transition);
  }

  .word-relations__chip--link:hover {
    border-color: var(--color-primary);
  }
</style>
