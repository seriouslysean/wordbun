---
import { getUrl, getWordUrl } from '#astro-utils/url-utils';

interface Props {
  words: string[];
}

const { words } = Astro.props;
---

<ul class="word-chips">
  {words.map(word => (
    <li>
      <a class="word-chips__chip" href={getUrl(getWordUrl(word))}>{word}</a>
    </li>
  ))}
</ul>

<style>
  /* A wrapped row of word-link chips, shared by relation groups and connection
     clusters. Scoped (not a global class) so the chip out-specifies the global
     `a:hover` color and its text stays put on hover -- only the border reacts. */
  .word-chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-small);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .word-chips__chip {
    display: inline-block;
    padding: var(--spacing-xs) var(--spacing-small);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    font-size: var(--font-size-small);
    color: var(--color-text-primary);
    text-decoration: none;
    transition: var(--transition);
  }

  .word-chips__chip:hover {
    border-color: var(--color-primary);
  }
</style>
