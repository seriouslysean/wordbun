---
import SectionHeading from '#components/SectionHeading.astro';
import WordLink from '#components/WordLink.astro';
import type { WordData } from '#types';
import { getLengthUrl, getLetterUrl, getPartOfSpeechUrl, getWordsYearUrl } from '#astro-utils/url-utils';
import { t } from '#utils/i18n-utils';

interface Props {
  wordLength: number;
  firstLetter: string;
  partOfSpeech?: string;
  year?: string;
  relatedByLength?: WordData[];
  relatedByLetter?: WordData[];
  relatedByPartOfSpeech?: WordData[];
  relatedByYear?: WordData[];
}

const {
  wordLength,
  firstLetter,
  partOfSpeech,
  year,
  relatedByLength = [],
  relatedByLetter = [],
  relatedByPartOfSpeech = [],
  relatedByYear = [],
} = Astro.props;

interface Group {
  key: string;
  href: string;
  label: string;
  words: WordData[];
}

const groups: Group[] = [];

if (relatedByLength.length > 0) {
  groups.push({
    key: 'length',
    href: getLengthUrl(wordLength),
    label: t('word.length_label', { length: wordLength }),
    words: relatedByLength,
  });
}

if (firstLetter && relatedByLetter.length > 0) {
  groups.push({
    key: 'letter',
    href: getLetterUrl(firstLetter),
    label: t('word.letter_words', { letter: firstLetter.toUpperCase() }),
    words: relatedByLetter,
  });
}

if (partOfSpeech && relatedByPartOfSpeech.length > 0) {
  groups.push({
    key: 'pos',
    href: getPartOfSpeechUrl(partOfSpeech),
    label: t(`parts_of_speech.${partOfSpeech}`),
    words: relatedByPartOfSpeech,
  });
}

if (year && relatedByYear.length > 0) {
  groups.push({
    key: 'year',
    href: getWordsYearUrl(year),
    label: year,
    words: relatedByYear,
  });
}

const hasGroups = groups.length > 0;
---

{hasGroups && (
  <section class="word-context" aria-label={t('word.related_words')}>
    <SectionHeading text={t('word.related_words')} />
    <div class="word-context__grid">
      {groups.map(group => (
        <div class="word-context__group">
          <h3 class="word-context__group-title">
            <a href={group.href} class="word-context__group-link">{group.label}</a>
          </h3>
          <ul class="word-context__list">
            {group.words.map(word => (
              <li><WordLink word={word} compact /></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .word-context {
    width: 100%;
    max-width: var(--content-width-medium);
    margin: var(--spacing-large) auto;
    padding: 0 var(--spacing-base);
  }

  .word-context__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-large);
  }

  .word-context__group {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-small);
  }

  .word-context__group-title {
    margin: 0;
    padding-bottom: var(--spacing-xs);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-medium);
  }

  .word-context__group-link {
    color: var(--color-primary);
    text-decoration: none;
  }

  .word-context__group-link:hover,
  .word-context__group-link:focus-visible {
    text-decoration: underline;
  }

  .word-context__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  @media (min-width: 768px) {
    .word-context__grid {
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      column-gap: var(--spacing-large);
    }
  }
</style>
