---
import { getAdjacentWords, getWordsFromCollection, extractWordDefinition } from '#astro-utils/word-data-utils';
import {
  getAlphabeticalNeighbors,
  groupWordsByLength,
  groupWordsByLetter,
  groupWordsByPartOfSpeech,
  groupWordsByYear,
  sortWordsAlphabetically,
} from '#utils/word-data-utils';
import WordPage from '#components/WordPage.astro';
import { slugify } from '#astro-utils/url-utils';
import type { WordData } from '#types';

export async function getStaticPaths() {
  const allWords = await getWordsFromCollection();

  const byLength = groupWordsByLength(allWords);
  const byLetter = groupWordsByLetter(allWords);
  const byPartOfSpeech = groupWordsByPartOfSpeech(allWords);
  const byYear = groupWordsByYear(allWords);
  const alphaSorted = sortWordsAlphabetically(allWords);

  // oxlint-disable-next-line consistent-function-scoping
  const pickRecent = (pool: WordData[], currentDate: string) =>
    pool
      .filter(w => w.date !== currentDate)
      .toSorted((a, b) => b.date.localeCompare(a.date))
      .slice(0, 3);

  const paths = allWords.map(wordData => {
    const { previousWord, nextWord } = getAdjacentWords(wordData.date, allWords);
    const { previousWord: alphaPreviousWord, nextWord: alphaNextWord } = getAlphabeticalNeighbors(wordData, alphaSorted);

    const wordLength = wordData.word.length;
    const firstLetter = wordData.word.charAt(0).toLowerCase();
    const year = wordData.date.substring(0, 4);
    const { partOfSpeech } = extractWordDefinition(wordData);

    const lengthPool = byLength[wordLength] ?? [];
    const letterPool = byLetter[firstLetter] ?? [];
    const posPool = partOfSpeech ? (byPartOfSpeech[partOfSpeech] ?? []) : [];
    const yearPool = byYear[year] ?? [];

    return {
      params: { word: slugify(wordData.word) },
      props: {
        wordData,
        previousWord,
        nextWord,
        alphaPreviousWord,
        alphaNextWord,
        contextData: {
          wordLength,
          firstLetter,
          partOfSpeech,
          year,
          lengthCount: lengthPool.length,
          letterCount: letterPool.length,
          partOfSpeechCount: posPool.length,
          yearCount: yearPool.length,
          relatedByLength: pickRecent(lengthPool, wordData.date),
          relatedByLetter: pickRecent(letterPool, wordData.date),
          relatedByPartOfSpeech: pickRecent(posPool, wordData.date),
          relatedByYear: pickRecent(yearPool, wordData.date),
        },
      },
    };
  });

  return paths;
}

const { wordData, previousWord, nextWord, alphaPreviousWord, alphaNextWord, contextData } = Astro.props;
---

<WordPage wordData={wordData} previousWord={previousWord} nextWord={nextWord} alphaPreviousWord={alphaPreviousWord} alphaNextWord={alphaNextWord} contextData={contextData} />
