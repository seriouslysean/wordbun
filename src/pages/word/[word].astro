---
import { getAdjacentWords, getWordsFromCollection, extractWordDefinition } from '#astro-utils/word-data-utils';
import { groupWordsByLength, groupWordsByLetter, groupWordsByPartOfSpeech, groupWordsByYear } from '#utils/word-data-utils';
import WordPage from '#components/WordPage.astro';
import { slugify } from '#astro-utils/url-utils';

export async function getStaticPaths() {
  const RELATED_LIMIT = 3;

  // Date descending: most recent first. Excludes the current word.
  const pickRecent = (pool: import('#types').WordData[], currentDate: string) =>
    pool
      .filter(w => w.date !== currentDate)
      .slice()
      .sort((a, b) => b.date.localeCompare(a.date))
      .slice(0, RELATED_LIMIT);

  const allWords = await getWordsFromCollection();

  const byLength = groupWordsByLength(allWords);
  const byLetter = groupWordsByLetter(allWords);
  const byPartOfSpeech = groupWordsByPartOfSpeech(allWords);
  const byYear = groupWordsByYear(allWords);

  const paths = allWords.map(wordData => {
    const { previousWord, nextWord } = getAdjacentWords(wordData.date, allWords);

    const wordLength = wordData.word.length;
    const firstLetter = wordData.word.charAt(0).toLowerCase();
    const year = wordData.date.substring(0, 4);
    const { partOfSpeech } = extractWordDefinition(wordData);

    const lengthBucket = byLength[wordLength] ?? [];
    const letterBucket = byLetter[firstLetter] ?? [];
    const partOfSpeechBucket = partOfSpeech ? (byPartOfSpeech[partOfSpeech] ?? []) : [];
    const yearBucket = byYear[year] ?? [];

    return {
      params: { word: slugify(wordData.word) },
      props: {
        wordData,
        previousWord,
        nextWord,
        contextData: {
          wordLength,
          firstLetter,
          partOfSpeech,
          year,
          relatedByLength: pickRecent(lengthBucket, wordData.date),
          relatedByLetter: pickRecent(letterBucket, wordData.date),
          relatedByPartOfSpeech: pickRecent(partOfSpeechBucket, wordData.date),
          relatedByYear: pickRecent(yearBucket, wordData.date),
        },
      },
    };
  });

  return paths;
}

const { wordData, previousWord, nextWord, contextData } = Astro.props;
---

<WordPage wordData={wordData} previousWord={previousWord} nextWord={nextWord} contextData={contextData} />
