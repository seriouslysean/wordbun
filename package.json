{
  "name": "occasional-wotd",
  "type": "module",
  "version": "3.12.0",
  "description": "Template for creating an occasional word of the day site",
  "keywords": [
    "word-of-the-day",
    "vocabulary",
    "learning",
    "astro",
    "static-site",
    "template"
  ],
  "author": "Sean Kennedy <sean@codeserious.com>",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "tool:add-word": "tsx tools/add-word.ts",
    "tool:generate-all-images": "npm run tool:generate-images && npm run tool:generate-images --generic",
    "tool:generate-images": "tsx tools/generate-images.ts",
    "tool:local": "tsx -r dotenv/config",
    "tool:migrate-preserve-case": "tsx tools/migrate-preserve-case.ts",
    "tool:regenerate-all-words": "tsx tools/regenerate-all-words.ts",
    "tool:sync": "./tools/sync-upstream.sh",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "typecheck": "astro check",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "astro": "^6.3.3",
    "entities": "^8.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.2",
    "@playwright/test": "^1.60.0",
    "@sentry/astro": "^10.53.1",
    "@sentry/node": "^10.53.1",
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv": "^17.4.2",
    "lefthook": "^2.1.6",
    "lightningcss": "^1.32.0",
    "opentype.js": "^2.0.0",
    "oxlint": "^1.65.0",
    "sharp": "^0.34.5",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "imports": {
    "#components/*": "./src/components/*",
    "#layouts/*": "./src/layouts/*",
    "#astro-utils/*": "./src/utils/*",
    "#utils/*": "./utils/*",
    "#types": "./types/index.ts",
    "#types/*": "./types/*",
    "#constants/*": "./constants/*",
    "#config/*": "./config/*",
    "#adapters": "./adapters/index.ts",
    "#adapters/*": "./adapters/*",
    "#data/*": "./data/*",
    "#styles/*": "./src/styles/*",
    "#assets/*": "./src/assets/*",
    "#tools/*": "./tools/*",
    "#locales/*": "./locales/*",
    "#tests/*": "./tests/*"
  }
}
