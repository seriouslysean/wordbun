# =============================================================================
# REQUIRED VARIABLES - Must be set for the application to work
# =============================================================================

# Site Identity - Required for Astro builds and SEO
# Full domain (e.g., https://example.com)
SITE_URL=
SITE_TITLE="(Occasional) Word of the Day"
SITE_DESCRIPTION="Educational vocabulary site featuring interesting words"
SITE_ID=occasional-wotd

# =============================================================================
# OPTIONAL CONFIGURATION - Has sensible defaults
# =============================================================================

# Dictionary Service - Required for word generation tools
# merriam-webster or wordnik
DICTIONARY_ADAPTER=merriam-webster
# Fallback chain when primary fails (comma-separated, tried in order)
# Use wordnik,wiktionary if you have a Wordnik API key for broader coverage
DICTIONARY_FALLBACK=wiktionary
# Merriam-Webster: get key from https://dictionaryapi.com/
MERRIAM_WEBSTER_API_KEY=
MERRIAM_WEBSTER_API_URL=https://dictionaryapi.com/api/v3/references
# collegiate, medical, learners, sd2, sd3, spanish, ithesaurus
MERRIAM_WEBSTER_DICTIONARY=collegiate
# Wordnik: get key from https://developer.wordnik.com/
WORDNIK_API_KEY=
WORDNIK_API_URL=https://api.wordnik.com/v4
WORDNIK_WEBSITE_URL=https://www.wordnik.com

# Data Source
# Subdirectory for word data and images. When set, paths become
# data/{SOURCE_DIR}/words/ and public/{SOURCE_DIR}/images/.
# When unset (or empty), paths use the root: data/words/ and public/images/.
# Upstream demo uses SOURCE_DIR=demo. Downstream repos leave it unset.
SOURCE_DIR=""

# Deployment
# Subdirectory path (/ for root, /blog for subdirectory)
BASE_PATH=/

# Site Metadata
SITE_LOCALE="en-US"
# Your name for attribution
SITE_AUTHOR=""
# Your website URL
SITE_AUTHOR_URL=""
# Custom attribution text
SITE_ATTRIBUTION_MESSAGE=""
SITE_KEYWORDS="vocabulary,word of the day,education,learning,dictionary,definitions"

# humans.txt Configuration (will be compiled into the build)
HUMANS_WORD_CURATOR=""
HUMANS_DEVELOPER_NAME=""
HUMANS_DEVELOPER_CONTACT=""
HUMANS_DEVELOPER_SITE=""

# =============================================================================
# FEATURE FLAGS - Enable optional functionality
# =============================================================================

# Theme Customization (override default orange theme)
# Main brand color (default: #9a3412)
COLOR_PRIMARY=""
# Light variant (default: #c2410c)
COLOR_PRIMARY_LIGHT=""
# Dark variant (default: #7c2d12)
COLOR_PRIMARY_DARK=""

# Dark Mode (opt-in: set COLOR_DARK_BACKGROUND to enable)
# When set, dark mode activates for users with system dark preference.
# Unset values fall back to light-mode colors.
# COLOR_DARK_BACKGROUND=""
# COLOR_DARK_BACKGROUND_LIGHT=""
# COLOR_DARK_PRIMARY=""
# COLOR_DARK_PRIMARY_LIGHT=""
# COLOR_DARK_PRIMARY_DARK=""
# COLOR_DARK_TEXT=""
# COLOR_DARK_TEXT_LIGHT=""
# COLOR_DARK_BORDER=""

# Google Analytics (requires GA_MEASUREMENT_ID when enabled)
GA_ENABLED="false"
# Google Analytics 4 Measurement ID
GA_MEASUREMENT_ID=""

# Development Configuration (auto-set in most environments)
NODE_ENV="development"

# Sentry Error Tracking (requires DSN, ORG, PROJECT when enabled)
SENTRY_ENABLED="false"
# Sentry Data Source Name
SENTRY_DSN=""
# Sentry organization
SENTRY_ORG=""
# Sentry project name
SENTRY_PROJECT=""
# For sourcemap uploads
SENTRY_AUTH_TOKEN=""
SENTRY_ENVIRONMENT="development"
# Auto-generated if not set
# SENTRY_RELEASE=

# CI Configuration (auto-set in CI environments, don't set manually)
# CI=true
